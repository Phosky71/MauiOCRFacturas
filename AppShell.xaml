<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiOCRFacturas.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:MauiOCRFacturas.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent
            x:Name="main"
            Route="main"
            Title="Escaner"
            Icon="camera.png"
            ContentTemplate="{DataTemplate views:MainPage}" />

        <ShellContent
            x:Name="historial"
            Route="historial"
            Title="Historial"
            Icon="list.png"
            ContentTemplate="{DataTemplate views:HistorialPage}" />
        
        <ShellContent
            x:Name="vision"
            Route="vision"
            Title="Objetos"
            Icon="eye.png"
            ContentTemplate="{DataTemplate views:VisionPage}" />
        
        <ShellContent
            x:Name="traductor"
            Route="traductor"
            Title="Traductor"
            Icon="micro.png"
            ContentTemplate="{DataTemplate views:TraductorPage}" />
        
        <ShellContent
            x:Name="resumen"
            Route="resumen"
            Title="Resumen Voz"
            Icon="micro.png"
            ContentTemplate="{DataTemplate views:VoiceSummaryPage}" />
    </TabBar>

</Shell>
