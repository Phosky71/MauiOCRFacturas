<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiOCRFacturas.Views.VoiceSummaryPage"
             Title="Voz a Resumen">
   <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Estado del micrófono -->
            <Frame BackgroundColor="#EEF2FF" CornerRadius="12" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Grabación de Voz"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="#3730A3"/>
                    <Label x:Name="StatusLabel"
                           Text="Presiona el botón para empezar a grabar"
                           FontSize="14" TextColor="#6B7280"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Botón grabar -->
            <Button x:Name="RecordButton"
                    Text="🎙️ Iniciar Grabación"
                    BackgroundColor="#4F46E5"
                    TextColor="White"
                    CornerRadius="12"
                    FontSize="16"
                    HeightRequest="56"
                    Clicked="OnRecordClicked"/>

            <!-- Transcripción -->
            <Frame CornerRadius="12" Padding="16"
                   IsVisible="{Binding HasTranscription}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="📝 Transcripción"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="#1F2937"/>
                    <Label x:Name="TranscriptionLabel"
                           Text="{Binding TranscriptionText}"
                           FontSize="14" TextColor="#374151"
                           LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Botón resumir -->
            <Button x:Name="SummarizeButton"
                    Text="✨ Generar Resumen con IA"
                    BackgroundColor="#059669"
                    TextColor="White"
                    CornerRadius="12"
                    FontSize="16"
                    HeightRequest="56"
                    IsVisible="{Binding HasTranscription}"
                    Clicked="OnSummarizeClicked"/>

            <!-- Indicador de carga -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="#4F46E5"
                               HeightRequest="40"/>

            <!-- Resumen generado -->
            <Frame CornerRadius="12" Padding="16"
                   BackgroundColor="#F0FDF4"
                   IsVisible="{Binding HasSummary}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="🤖 Resumen generado por IA"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="#065F46"/>
                    <Label x:Name="SummaryLabel"
                           Text="{Binding SummaryText}"
                           FontSize="14" TextColor="#374151"
                           LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Botón limpiar -->
            <Button Text="🗑️ Nueva Grabación"
                    BackgroundColor="#9CA3AF"
                    TextColor="White"
                    CornerRadius="12"
                    FontSize="14"
                    HeightRequest="48"
                    IsVisible="{Binding HasSummary}"
                    Clicked="OnClearClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>